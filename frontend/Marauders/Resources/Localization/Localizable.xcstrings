    "This chapter has no verified AR target yet. Its curated text and Audio Experience remain available offline.": {
      "localizations": {
        "es": { "stringUnit": { "state": "translated", "value": "Este capítulo aún no tiene un objetivo de RA verificado. Su texto seleccionado y la experiencia de audio siguen disponibles sin conexión." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ce chapitre ne dispose pas encore de cible RA vérifiée. Son texte sélectionné et son expérience audio restent disponibles hors ligne." } },
        "hi": { "stringUnit": { "state": "translated", "value": "इस अध्याय के लिए अभी तक कोई सत्यापित एआर लक्ष्य नहीं है। इसका चयनित पाठ और ऑडियो अनुभव ऑफ़लाइन उपलब्ध हैं।" } }
      }
    },
    "This curated local fallback is separate from live AI questions, which are available in mapped AR chapters.": {
      "localizations": {
        "es": { "stringUnit": { "state": "translated", "value": "Este contenido local seleccionado es independiente de las preguntas en directo a la IA, disponibles en los capítulos de RA con objetivos asignados." } },
