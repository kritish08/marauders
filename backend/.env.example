# Copy to .env and fill in. All resources live in your Azure AI Foundry project.

# --- Azure OpenAI (Foundry) : GPT-4o + Whisper (+ optional TTS deployment) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_GPT_DEPLOYMENT=gpt-4o        # overwrite with bench_models.py winner
AZURE_WHISPER_DEPLOYMENT=whisper
CHAT_DEPLOYMENTS=gpt-4o            # comma-separated list for bench_models.py (add gpt-5.6 etc.)

# --- auth: required header X-App-Key on /ask (leave empty ONLY for local dev) ---
APP_KEY=

# --- TTS provider: "speech" (recommended for Hindi) or "openai" ---
TTS_PROVIDER=speech

# if TTS_PROVIDER=speech : Azure Speech resource (create in same region; centralindia has hi-IN voices)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
SPEECH_VOICE_EN=en-IN-NeerjaNeural
SPEECH_VOICE_HI=hi-IN-SwaraNeural
SPEECH_VOICE_FR=fr-FR-DeniseNeural
SPEECH_VOICE_ES=es-ES-ElviraNeural

# if TTS_PROVIDER=openai : a TTS deployment in Foundry (e.g. gpt-4o-mini-tts)
AZURE_TTS_DEPLOYMENT=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
